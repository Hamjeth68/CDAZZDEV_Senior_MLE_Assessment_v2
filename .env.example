# Copy this file to `.env` and set values locally.
# Never commit populated secrets.

# LLM Provider Configuration

# OpenRouter API Key (https://openrouter.ai)
# Primary provider for LLM requests
OPENROUTER_API_KEY=

# Groq API Key (https://console.groq.com)
# Fallback provider if OpenRouter is unavailable
GROQ_API_KEY=